#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# Parse args
WITH_NIX=false
WITH_GNOME_I3=false
for arg in "$@"; do
  case "$arg" in
    --with-nix) WITH_NIX=true ;;
    --with-gnome-i3) WITH_GNOME_I3=true ;;
    --help|-h)
      echo "Usage: install-all [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --with-gnome-i3  Install GNOME+i3 session files (requires sudo)"
      echo "  --with-nix       Install Nix and Home Manager (bootstrap from scratch)"
      echo "  --help, -h       Show this help message"
      exit 0
      ;;
  esac
done

# Link a per-file set from a source dir into a target dir, but skip when the
# target dir already resolves to the source dir (e.g. ~/.bin -> dotfiles/.bin).
# Without this guard, ln -sf trashes the in-repo symlinks by replacing them
# with self-loops via the parent symlink.
link_dir_contents() {
  local src_dir="$1"
  local dst_dir="$2"
  local file_test="$3"  # '-e' or '-f' to filter sources

  mkdir -p "$dst_dir"
  local src_real dst_real
  src_real="$(readlink -f "$src_dir")"
  dst_real="$(readlink -f "$dst_dir" 2>/dev/null || echo "$dst_dir")"
  if [[ "$src_real" == "$dst_real" ]]; then
    echo "  $dst_dir already resolves to $src_real, skipping per-file links"
    return 0
  fi

  for script in "$src_dir"/*; do
    [ "$file_test" "$script" ] || continue
    local name target
    name="$(basename "$script")"
    target="$dst_dir/$name"
    ln -sf "$script" "$target"
    echo "  Linked $name"
  done
}

echo "=== Installing scripts to ~/.bin/ ==="
link_dir_contents "$ROOT/.bin" "$HOME/.bin" -e
echo "Done. Make sure ~/.bin is in your PATH."

echo "=== Installing Nautilus scripts ==="
link_dir_contents "$ROOT/.local/share/nautilus/scripts" "$HOME/.local/share/nautilus/scripts" -f

# Install Claude Code configuration
"$ROOT/scripts/install/install-claude-config"

# Install Codex configuration
"$ROOT/scripts/install/install-codex-config"

# Install OpenCode configuration
"$ROOT/scripts/install/install-opencode-config"

# Install GNOME+i3 session files (if requested)
if [ "$WITH_GNOME_I3" = true ]; then
  "$ROOT/scripts/install/install-gnome-i3"
fi

# Install Nix + Home Manager (if requested)
if [ "$WITH_NIX" = true ]; then
  "$ROOT/scripts/install/install-nix-hm"
fi

echo ""
echo "install-all complete."
